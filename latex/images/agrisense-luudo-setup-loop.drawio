  <diagram name="Hình 24 - setup và loop" id="fig-luudo">
    <mxGraphModel dx="900" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t1" value="Lưu đồ thuật toán ESP32 — Phần setup() và loop() (main.cpp)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="120" y="16" width="660" height="32" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="PUBLISH_INTERVAL=5000 ms · MQTT_RETRY_MS=5000 ms · GPIO: DHT=4, Soil=34, I2C 21/22, Relay=26, Buzzer=27" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontColor=#546E7A;" vertex="1" parent="1">
          <mxGeometry x="80" y="48" width="740" height="36" as="geometry" />
        </mxCell>

        <!-- SETUP -->
        <mxCell id="s0" value="Bắt đầu (reset)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="96" width="180" height="48" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="Serial.begin(115200)&#xa;In banner AgriSense IoT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="160" width="240" height="52" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="pinMode: Relay GPIO26, Buzzer GPIO27&#xa;pinMode(SOIL_PIN, INPUT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="228" width="280" height="52" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="dht.begin()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="296" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="initBH1750() → lightSensorOK&#xa;(Wire 21/22, mode High-Res)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="352" width="300" height="52" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="espClient.setInsecure() (TLS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="420" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="setupWiFi() — chờ WL_CONNECTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3949AB;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="476" width="280" height="44" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="mqttClient.setServer(BROKER, 8883)&#xa;setCallback(mqttCallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="536" width="340" height="52" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="&quot;Setup complete!&quot; (Serial)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="604" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="▼ Vào loop() vĩnh viễn ▼" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="664" width="300" height="44" as="geometry" />
        </mxCell>

        <!-- LOOP -->
        <mxCell id="l0" value="now = millis()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="732" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l1" value="WiFi.status() == WL_CONNECTED ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="788" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="l1a" value="setupWiFi()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FF8F00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="804" width="120" height="48" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="MQTT connected ?&#xa;(hoặc đủ MQTT_RETRY_MS → reconnectMQTT)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="300" y="892" width="300" height="88" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="mqttClient.loop()&#xa;(callback nhận control/config)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="1000" width="280" height="52" as="geometry" />
        </mxCell>
        <mxCell id="l4" value="pumpRelayState &amp;&amp; now ≥ pumpAutoOffTime ?&#xa;→ tắt bơm, clear timer" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="290" y="1072" width="320" height="88" as="geometry" />
        </mxCell>
        <mxCell id="l5" value="autoIrrigationEnabled &amp;&amp; đất &lt; 30% &amp;&amp; bơm tắt ?&#xa;→ bật bơm 10s (pumpAutoOffTime)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="280" y="1180" width="340" height="88" as="geometry" />
        </mxCell>
        <mxCell id="l6" value="now - lastPublish ≥ PUBLISH_INTERVAL ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0277BD;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="1290" width="300" height="72" as="geometry" />
        </mxCell>
        <mxCell id="l7" value="Khối chi tiết: đọc cảm biến, buzzer, publish MQTT&#xa;→ Hình 25 (fig:luudo-2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="1390" width="380" height="56" as="geometry" />
        </mxCell>
        <mxCell id="l8" value="Quay lại đầu loop&#xa;(lastPublish giữ nguyên nếu chưa publish)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;fontSize=9;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="1300" width="220" height="52" as="geometry" />
